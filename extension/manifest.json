{
  "manifest_version": 3,
  "name": "Partiful LI Scraper",
  "version": "2.0",
  "description": "Extract attendee names from Partiful events and find their LinkedIn profiles.",
  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": ["https://www.google.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
